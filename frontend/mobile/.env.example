# Required: n8n instance origin (HTTPS), no trailing slash. Example: https://yourname.app.n8n.cloud
# Copy this file to `.env` in the same folder, set the value, then restart Metro: `npx expo start -c`
# EAS / TestFlight: set the same name in `eas.json` build env or Expo dashboard → Environment variables.
EXPO_PUBLIC_N8N_BASE_URL=

# Optional path overrides (defaults match repo config.yaml)
# EXPO_PUBLIC_ONBOARDING_PATH=/webhook/healthgenie/onboarding
# EXPO_PUBLIC_CHECKPOINT_PATH=/webhook/healthgenie/checkpoint

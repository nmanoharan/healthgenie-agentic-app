# Required for browser → n8n (no proxy). Example: https://yourname.app.n8n.cloud
VITE_N8N_BASE_URL=

# Dev CORS workaround: set true and set VITE_N8N_PROXY_TARGET to the same n8n origin.
# Requests use relative /webhook/... and Vite proxies to n8n.
VITE_USE_PROXY=false
VITE_N8N_PROXY_TARGET=

# Optional overrides if your webhook paths differ from repo config.yaml
# VITE_ONBOARDING_PATH=/webhook/healthgenie/onboarding
# VITE_CHECKPOINT_PATH=/webhook/healthgenie/checkpoint
